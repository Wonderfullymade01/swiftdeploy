version: "3.9"

networks:
  {{ network_name }}:
    driver: {{ network_driver }}
  opa-internal:
    driver: bridge

volumes:
  app_logs:

services:
  {{ service_name }}:
    image: {{ service_image }}
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ app_version }}
      - APP_PORT={{ service_port }}
    networks:
      - {{ network_name }}
    volumes:
      - app_logs:/logs
    restart: unless-stopped
    cap_drop:
      - ALL
    user: "1000"
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:{{ service_port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 5
    expose:
      - "{{ service_port }}"

  nginx:
    image: {{ nginx_image }}
    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - app_logs:/var/log/nginx
    networks:
      - {{ network_name }}
    depends_on:
      - {{ service_name }}
    restart: unless-stopped

  opa:
    image: openpolicyagent/opa:latest
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:8181"
      - "--log-level=error"
      - "/policies"
    volumes:
      - ./policies:/policies:ro
    networks:
      - opa-internal
    ports:
      - "8181:8181"
    restart: unless-stopped